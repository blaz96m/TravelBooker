{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Global": {
      "PermitLimit": 10000,
      "WindowSeconds": 60
    },
    "SensitiveEndpoint": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6
    }
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your@email.com",
    "Password": "your-app-password",
    "FromName": "TravelBooker",
    "FromEmail": "your@email.com"
  }
}
